# VITE_GEMINI_API_KEY: Required for Gemini AI API calls.
# Vite automatically exposes variables prefixed with VITE_ to the client.
# Users configure this via the Secrets panel in the AI Studio UI.
# Access in code via: import.meta.env.VITE_GEMINI_API_KEY
VITE_GEMINI_API_KEY="YOUR_GEMINI_API_KEY_HERE"

# VITE_APP_URL: The URL where this app is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Access in code via: import.meta.env.VITE_APP_URL
VITE_APP_URL="http://localhost:3000"
